<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F4F5F6"
    tools:context=".DecoderActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Giải mã Video ra YUV"
        android:textColor="#1E66F5"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="24dp" />

    <!-- Video details card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN BẢN GHI VIDEO"
                android:textColor="#8839EF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tv_video_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đường dẫn: N/A"
                android:textColor="#1E1E2E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_video_resolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Độ phân giải: N/A"
                android:textColor="#1E1E2E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_video_codec"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Codec: N/A"
                android:textColor="#1E1E2E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_video_fps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tốc độ khung hình (FPS): N/A"
                android:textColor="#1E1E2E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_video_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thời lượng: N/A"
                android:textColor="#1E1E2E"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Options card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ĐỊNH DẠNG MÀU YUV ĐẦU RA"
                android:textColor="#40A02B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Spinner
                android:id="@+id/sp_color_format"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:padding="8dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Progress card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tv_progress_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang giải mã: Khung hình 0"
                    android:textColor="#1E1E2E"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_progress_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#1E66F5"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/pb_decode"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:layout_marginBottom="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btn_select_destination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📁 Chọn nơi lưu tệp YUV"
        android:backgroundTint="#8839EF"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_destination_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nơi lưu: Chưa chọn"
        android:textColor="#4C4F69"
        android:textSize="13sp"
        android:layout_marginBottom="20dp"
        android:gravity="center_horizontal" />

    <Button
        android:id="@+id/btn_toggle_decode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎬 Bắt Đầu Giải Mã"
        android:backgroundTint="#1E66F5"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:enabled="false" />

</LinearLayout>
